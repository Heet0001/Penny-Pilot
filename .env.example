# =============================================================================
# Penny-Pilot environment variables
# Copy this file to .env for local development and fill the values.
# In production (Render / Railway / etc.) set these in the dashboard, do NOT
# commit a real .env to git.
# =============================================================================

# --- API Keys ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# --- MySQL database credentials ---
# Local dev example:
#   MYSQLHOST=localhost
#   MYSQLPORT=3306
#   MYSQLUSER=root
#   MYSQLPASSWORD=your_local_password
#   MYSQLDATABASE=penny_pilot
#   MYSQLSSL=false
#
# TiDB Cloud Serverless / Aiven / PlanetScale example (managed, requires SSL):
#   MYSQLHOST=gateway01.<region>.prod.aws.tidbcloud.com
#   MYSQLPORT=4000
#   MYSQLUSER=your_tidb_user
#   MYSQLPASSWORD=your_tidb_password
#   MYSQLDATABASE=penny_pilot
#   MYSQLSSL=true
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=penny_pilot
MYSQLSSL=false

# --- Application ---
# Leave PORT unset on Render / Railway (they inject their own).
PORT=3000
